# Base URL of the Java (Spring Boot) backend - see backend/README or the root
# README's "Backend" section. Also used by next.config.ts to proxy
# /api/backend/* to the backend so its cookies behave as first-party.
JAVA_API_URL="http://localhost:8080"

# Verifies the session cookie issued by the Java backend (src/proxy.ts,
# server.ts). Must be the EXACT same value as the backend's JWT_SECRET -
# generate with: openssl rand -base64 32
JWT_SECRET="replace-with-a-random-32-byte-secret"

# Shared secret the Java backend sends when it calls this app's internal
# /api/internal/realtime endpoint to push live dashboard updates (see
# server.ts and backend's RealtimeNotifier). Must match the backend's
# INTERNAL_REALTIME_SECRET.
INTERNAL_REALTIME_SECRET="replace-with-another-random-secret"

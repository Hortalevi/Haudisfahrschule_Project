# Postgres connection (see root docker-compose.yml for local defaults).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=haudis
DB_USER=haudis
DB_PASSWORD=haudis

# Must be the EXACT same value as the Next.js app's JWT_SECRET (.env) -
# generate with: openssl rand -base64 32
JWT_SECRET=replace-with-a-random-32-byte-secret

# Origin(s) allowed to call this API with credentials (comma-separated).
FRONTEND_ORIGIN=http://localhost:3000

# Where the Next.js app runs, and the shared secret it expects on the
# realtime webhook - must match its INTERNAL_REALTIME_SECRET (.env).
NEXT_INTERNAL_URL=http://localhost:3000
INTERNAL_REALTIME_SECRET=replace-with-another-random-secret

# false for local http dev; must be true once this is served over https.
COOKIE_SECURE=false
